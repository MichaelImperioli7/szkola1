<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ksiazki.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <CollectionView x:Name="Kolekcja"
                            ItemsSource="{Binding Ksiazki}"
                            SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout>
                            <VerticalStackLayout.Triggers>
                                <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding LiczbaStron}" Value="500">
                                    <Setter Property="BackgroundColor" Value="LightPink"/>
                                </DataTrigger>
                                <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding LiczbaStron}" Value="700">
                                    <Setter Property="BackgroundColor" Value="Orange"/>
                                </DataTrigger>
                            </VerticalStackLayout.Triggers>
                            <Label>
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0}, {1}">
                                        <Binding Path="Tytul"/>
                                        <Binding Path="Autor"/>
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label Text="{Binding Source={x:Reference Kolekcja}, Path='SelectedItem.Tytul', StringFormat='Wybrales: {0}', FallbackValue='Wybrałes...'}"/>
            <Entry Placeholder="Edytuj Tytul"
                   Text="{Binding Source={x:Reference Kolekcja}, Path='SelectedItem.Tytul' , Mode=TwoWay}"/>
            <Entry Placeholder="Edytuj Autora"
                   Text="{Binding Source={x:Reference Kolekcja}, Path='SelectedItem.Autor', Mode=TwoWay}"/>
            <Entry Placeholder="Liczba stron"
                   Keyboard="Numeric"
                   Text="{Binding Source={x:Reference Kolekcja}, Path='SelectedItem.LiczbaStron', Mode=TwoWay}"/>
            <Stepper Minimum="0"
                     Maximum="1000"
                     Value="{Binding Source={x:Reference Kolekcja}, Path='SelectedItem.LiczbaStron', Mode=TwoWay}"/>
            <Label Text="{Binding Source={x:Reference Kolekcja}, Path='SelectedItem.LiczbaStron', StringFormat='Liczba stron: {0}', FallbackValue='Liczba stron...'}"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
