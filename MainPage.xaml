<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp8.MainPage"
             Title="Game Rental">

    <Grid ColumnDefinitions="*, *" Padding="12" ColumnSpacing="12">

        <CollectionView Grid.Column="0"
                        ItemsSource="{Binding Games}"
                        SelectionMode="Single"
                        SelectionChanged="OnGameSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="7" Margin="0,0,0,10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold"/>
                            <Label Text="{Binding Genre}"/>
                            <Label Text="{Binding AvailableCopies, StringFormat='Available: {0}'}"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ScrollView Grid.Column="1">
            <VerticalStackLayout x:Name="DetailsPanel" IsVisible="False" Spacing="8">
                <Image x:Name="GameImage"
                   HeightRequest="200"
                   Aspect="AspectFit"
                   Margin="0,0,0,8" />
                <Label x:Name="NameLabel" FontSize="20" FontAttributes="Bold"/>
                <Label x:Name="YearLabel"/>
                <Label x:Name="GenreLabel"/>
                <Label x:Name="DeveloperLabel"/>
                <Label x:Name="DirectorLabel"/>
                <Label x:Name="CopiesLabel"/>
                <Label x:Name="RentedLabel"/>
                <HorizontalStackLayout Spacing="8" Margin="0,10,0,0">
                    <Button x:Name="RentButton" Text="Rent" Clicked="OnRentClicked" BackgroundColor="MediumSeaGreen"/>
                    <Button x:Name="ReturnButton" Text="Return" Clicked="OnReturnClicked" BackgroundColor="IndianRed"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>